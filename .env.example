# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:123456@localhost:5432/rust_app
DB_MAX_CONNECTIONS=20
DB_ACQUIRE_TIMEOUT_MS=2000

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6380

# -----------------------------------------------------------------------------
# Runtime concurrency and backpressure
# -----------------------------------------------------------------------------
HTTP_CONCURRENCY=128
HTTP_QUEUE_TIMEOUT_MS=250
UPLOAD_CONCURRENCY=4
UPLOAD_QUEUE_TIMEOUT_MS=1000
BCRYPT_CONCURRENCY=4
BCRYPT_QUEUE_TIMEOUT_MS=500
TRANSCODE_CONCURRENCY=2
WS_CONNECTION_QUEUE_CAPACITY=64

# -----------------------------------------------------------------------------
# JSON Web Token Credentials
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=my_ultra_secure_jwt_secret_key
JWT_MAXAGE=60

# -----------------------------------------------------------------------------
# GitHub OAuth
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=Ov23liep7Wl7aCqOC2Sm
GITHUB_CLIENT_SECRET=d0ae8e31725474c892479d1e6013c51ec6d9dd8f
GITHUB_REDIRECT_URI=https://app.coulsonzero.shop/api/auth/github/callback
FRONTEND_URL=https://www.coulsonzero.shop

# -----------------------------------------------------------------------------
# Pro subscription
# -----------------------------------------------------------------------------
# Hosted checkout page supplied by the payment provider.
PRO_CHECKOUT_URL=https://billing.example.com/checkout
# Shared only with the payment provider's server-to-server webhook.
SUBSCRIPTION_WEBHOOK_SECRET=replace-with-a-long-random-secret

# -----------------------------------------------------------------------------
# SMTP Server Settings
# -----------------------------------------------------------------------------
SMTP_SERVER=smtp.your-email-provider.com
SMTP_PORT=587                     # Common ports: 587 (TLS), 465 (SSL), 25 (non-secure)
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM_ADDRESS=no-reply@yourdomain.com
FRONTEND_URL=https://app.coulsonzero.shop
